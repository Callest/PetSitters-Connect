<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="PetSitters"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PetSitters">

        <!-- 1. LOGIN: The Start Screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 2. MAIN HOME -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <!-- 3. MAP -->
        <activity
            android:name=".MapsActivity"
            android:label="Pet Sitter Map"
            android:parentActivityName=".MainActivity" />

        <!-- 4. REGISTER -->
        <activity
            android:name=".RegisterSitterActivity"
            android:label="Register as Sitter"
            android:parentActivityName=".LoginActivity" />

        <!-- 5. PROFILE -->
        <activity
            android:name=".SitterProfileActivity"
            android:parentActivityName=".MapsActivity" />

        <!-- 6. MESSAGE -->
        <activity
            android:name=".MessageActivity"
            android:parentActivityName=".SitterProfileActivity" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="" />

    </application>
</manifest>
